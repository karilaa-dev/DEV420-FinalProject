<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<connectionStrings>
		<add name="MongoConnection"
			 connectionString="mongodb://localhost:27017/HospitalManagementDB" />

		<add name="HospitalSqlConnection"
			 connectionString="Data Source=GOONERSSEUR\SQLEXPRESS;Initial Catalog=HospitalManagementDB_SQL;Integrated Security=True;Encrypt=True;TrustServerCertificate=True" />
	</connectionStrings>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

</configuration>